# Normalize line endings: let Git decide text vs binary, store LF in the repo
* text=auto

# Force LF for cross-platform source/config
*.cs        text eol=lf
*.csproj    text eol=lf
*.slnx      text eol=lf
*.json      text eol=lf
*.config    text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.css       text eol=lf
*.md        text eol=lf
*.http      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Windows-specific scripts keep CRLF
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Treat as binary (no EOL conversion)
*.ico       binary
*.png       binary
*.jpg       binary
*.gif       binary
*.svg       text eol=lf
*.woff      binary
*.woff2     binary
